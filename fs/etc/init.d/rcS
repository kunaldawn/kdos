#!/bin/bash

# ██╗  ██╗██████╗  ██████╗ ███████╗
# ██║ ██╔╝██╔══██╗██╔═══██╗██╔════╝
# █████╔╝ ██║  ██║██║   ██║███████╗
# ██╔═██╗ ██║  ██║██║   ██║╚════██║
# ██║  ██╗██████╔╝╚██████╔╝███████║
# ╚═╝  ╚═╝╚═════╝  ╚═════╝ ╚══════╝
# ---------------------------------
#   KD's Homebrew Linux Distro
# ---------------------------------

# Mount all filesystems in fstab
mount -a

# ── Auto-run all numbered service scripts ─────────────────────────────────────
# Scripts must match the pattern:  /etc/init.d/NN_name.sh
# They are executed in numeric order with the argument 'start'.
# Each script is responsible for checking if its daemon exists before running.

INIT_DIR="/etc/init.d"
DISABLED_DIR="/etc/service.disabled"

for _script in "${INIT_DIR}"/[0-9][0-9]_*.sh; do
    [ -x "$_script" ] || continue
    _name=$(basename "$_script" | sed 's/^[0-9][0-9]_//;s/\.sh$//')
    if [ -f "${DISABLED_DIR}/${_name}" ]; then
        echo "[KDOS] Skipping disabled service: ${_name}"
        continue
    fi
    echo "[KDOS] Running: $(basename $_script) start"
    "$_script" start
done

unset _script

echo "KDOS Initialized."
