# pyurl - Get PyPI URL for a package
# Usage: ./pyurl.py <package_name> [version] (version is optional, if ommitted it returns latest version and url)
# Example: ./pyurl.py glean-sdk
# Example: ./pyurl.py glean-sdk 1.2.3

import sys
import json
import urllib.request
import urllib.error

def get_pypi_url(package_name, version=None):
    if version:
        url = f"https://pypi.org/pypi/{package_name}/{version}/json"
    else:
        url = f"https://pypi.org/pypi/{package_name}/json"

    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req) as response:
            data = json.loads(response.read().decode('utf-8'))
            
            if not version:
                version = data.get('info', {}).get('version')
                urls = data.get('releases', {}).get(version, [])
            else:
                urls = data.get('urls', [])
            
            # Prefer source distributions (.tar.gz usually)
            sdist_url = next((u['url'] for u in urls if u['packagetype'] == 'sdist'), None)
            
            if sdist_url:
                print(f"{version} {sdist_url}")
            else:
                # Fallback to the first available URL if no sdist is found
                if urls:
                    print(f"{version} {urls[0]['url']}")
                else:
                    print(f"Error: No download URLs found for {package_name} {version}")
                    sys.exit(1)
                    
    except urllib.error.HTTPError as e:
        if e.code == 404:
            print(f"Error: Package '{package_name}' or version '{version}' not found on PyPI.", file=sys.stderr)
        else:
            print(f"HTTP Error: {e.code} - {e.reason}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) < 2 or len(sys.argv) > 3:
        print("Usage: get_pypi_url.py <package_name> [version]", file=sys.stderr)
        print("Example: ./get_pypi_url.py glean-sdk", file=sys.stderr)
        sys.exit(1)
        
    pkg = sys.argv[1]
    ver = sys.argv[2] if len(sys.argv) == 3 else None
    get_pypi_url(pkg, ver)
